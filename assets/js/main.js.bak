	////////////////////////////////////////////////////
	//26.isotope
	$('.grid').imagesLoaded(function () {
		// init Isotope
		var $grid = $('.grid').isotope({
			itemSelector: '.grid-item',
			percentPosition: true,
			layoutMode: 'fitRows',
			masonry: {
				// use outer width of grid-sizer for columnWidth
				columnWidth: 1,
			},
			
		});
		

		// filter items on button click
		$('.masonary-menu').on('click', 'button', function () {
			var filterValue = $(this).attr('data-filter');
			$grid.isotope({ 
				filter: filterValue,
				animationOptions: {
					duration: 10000,
					easing: "linear",
					queue: true
				}
			});
			
		});

		//for menu active class
		$('.masonary-menu button').on('click', function (event) {
			$(this).siblings('.active').removeClass('active');
			$(this).addClass('active');
			event.preventDefault();
		});

	});	

		// 05. Search Js
		var tpSearch = {
			init: function() {
				this.searchBox = $(".tp-search-box");
				this.searchWrapper = $(".search-wrapper");
				this.searchInput = $(".header-search-form input");
				this.suggestions = $(".search-suggestions");
				this.searchCache = {};
				this.bindEvents();
			},

			bindEvents: function() {
				// Abrir/cerrar búsqueda
				this.searchBox.on("click", this.toggleSearch.bind(this));
				$(document).on("click", this.handleOutsideClick.bind(this));
				$(document).on("keydown", this.handleEscKey.bind(this));
				this.searchInput.on("input", this.debounce(this.handleSearch.bind(this), 300));
			},

			toggleSearch: function(e) {
				e.preventDefault();
				e.stopPropagation();
				this.searchWrapper.toggleClass("search-open");
				
				if (this.searchWrapper.hasClass("search-open")) {
					setTimeout(() => this.searchInput.focus(), 100);
				}
			},

			handleOutsideClick: function(e) {
				if (!$(e.target).closest('.search-wrapper').length) {
					this.searchWrapper.removeClass("search-open");
				}
			},

			handleEscKey: function(e) {
				if (e.key === "Escape") {
					this.searchWrapper.removeClass("search-open");
				}
			},

			handleSearch: function() {
				const query = this.searchInput.val().trim();
				
				if (query.length < 2) {
					this.suggestions.empty().hide();
					return;
				}
				
				if (this.searchCache[query]) {
					this.showSuggestions(this.searchCache[query], query);
					return;
				}
				
				this.fetchResults(query);
			},

			handleKeyNav: function(e) {
				const $items = this.suggestions.find(".suggestion-item");
				const $highlighted = $items.filter(".highlighted");
				
				switch (e.key) {
					case "ArrowDown":
						e.preventDefault();
						if ($highlighted.length === 0) {
							$items.first().addClass("highlighted");
						} else {
							$highlighted.removeClass("highlighted")
								.next(".suggestion-item").addClass("highlighted");
						}
						break;
						
					case "ArrowUp":
						e.preventDefault();
						if ($highlighted.length === 0) {
							$items.last().addClass("highlighted");
						} else {
							$highlighted.removeClass("highlighted")
								.prev(".suggestion-item").addClass("highlighted");
						}
						break;
						
					case "Enter":
						if ($highlighted.length) {
							e.preventDefault();
							window.location.href = $highlighted.data("url");
						}
						break;
				}
			},
			
			// Search object
			var Search = {
				init: function() {
					this.searchInput = $(".header-search-form input");
					this.suggestions = $(".search-suggestions");
					this.searchTimeout = null;
					this.searchIndex = null;
					this.searchCache = {};
					
					this.loadSearchIndex();
					this.bindEvents();
				},
				
				loadSearchIndex: function() {
					var self = this;
					$.getJSON("assets/js/search-index.json", function(data) {
						self.searchIndex = data;
					});
				},
				
				bindEvents: function() {
					var self = this;
					this.searchInput.on("input", function() {
						clearTimeout(self.searchTimeout);
						const query = $(this).val().trim();
						
						if (query.length < 2) {
							self.suggestions.empty().hide();
							return;
						}
						
						self.searchTimeout = setTimeout(function() {
							self.performSearch(query);
						}, 300);
					});
				},
				
				performSearch: function(query) {
					var self = this;
					if (!this.searchIndex) return;
					
					if (this.searchCache[query]) {
						this.showSuggestions(this.searchCache[query], query);
						return;
					}
					
					const results = this.searchIndex
						.map(function(item) {
							const searchText = (item.title + " " + 
								item.content + " " + 
								item.excerpt + " " + 
								item.tags.join(" ")).toLowerCase();
							const queryLower = query.toLowerCase();
							
							if (searchText.includes(queryLower)) {
								return {
									title: item.title,
									excerpt: item.excerpt || "",
									url: item.url,
									tags: item.tags,
									score: searchText.indexOf(queryLower)
								};
							}
							return null;
						})
						.filter(function(item) { return item !== null; })
						.sort(function(a, b) { return a.score - b.score; })
						.slice(0, 5);
					
					this.searchCache[query] = results;
					this.showSuggestions(results, query);
				},
				
				showSuggestions: function(results, query) {
					if (results.length === 0) {
						this.suggestions.html(
							'<div class="suggestion-item">' +
							'<div class="suggestion-title">No se encontraron resultados</div>' +
							'</div>'
						).show();
						return;
					}
					
					const html = results.map(function(result) {
						return '<div class="suggestion-item" data-url="' + result.url + '">' +
							'<div class="suggestion-title">' + this.highlightText(result.title, query) + '</div>' +
							'<div class="suggestion-excerpt">' + this.highlightText(result.excerpt, query) + '</div>' +
							'<div class="suggestion-category">' + result.tags.join(" · ") + '</div>' +
							'</div>';
					}, this).join("");
					
					this.suggestions.html(html).show();
					
					// Bind click events to suggestion items
					var self = this;
					this.suggestions.find(".suggestion-item").on("click", function() {
						window.location.href = $(this).data("url");
					});
				},
				
				highlightText: function(text, query) {
					if (!text) return "";
					const regex = new RegExp("(" + this.escapeRegExp(query) + ")", "gi");
					return text.replace(regex, '<span class="search-highlight">$1</span>');
				},
				
				escapeRegExp: function(string) {
					return string.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
				}
			};
		});

		function showSuggestions(results, query) {
			const $suggestions = $(".search-suggestions");
			
			if (results.length === 0) {
				$suggestions.html(`
					<div class="suggestion-item">
						<div class="suggestion-title">No se encontraron resultados</div>
					</div>
				`).show();
				return;
			}
			
			const html = results.map(result => `
				<div class="suggestion-item" data-url="${result.url}">
					<div class="suggestion-title">${highlightText(result.title, query)}</div>
					<div class="suggestion-excerpt">${highlightText(result.excerpt || "", query)}</div>
					<div class="suggestion-category">${result.tags.join(" · ")}</div>
				</div>
			`).join("");
			
			$suggestions.html(html).show();
		}

		function highlightText(text, query) {
			if (!text) return "";
			const regex = new RegExp(`(${escapeRegExp(query)})`, "gi");
			return text.replace(regex, '<span class="search-highlight">$1</span>');
		}

		function escapeRegExp(string) {
			return string.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
		}

		// Continuar con el resto del código...
			const searchBox = $(".tp-search-box");
			const searchWrapper = $(".tp-search-wrapper");
			const searchClose = $(".tp-search-close");
			const searchInput = $(".tp-search-form input");
			let searchTimeout;

			// Abrir búsqueda
			searchBox.on("click", function (e) {
				e.preventDefault();
				e.stopPropagation();
				openSearch();
			});

			// Función para abrir búsqueda
			function openSearch() {
				searchWrapper.addClass("show");
				setTimeout(() => {
					searchInput.val("").focus();
				}, 100);
				$("body").css("overflow", "hidden");
			}

			// Función para cerrar búsqueda
			function closeSearch() {
				searchWrapper.removeClass("show");
				$("body").css("overflow", "");
				searchInput.val("");
				$(".search-suggestions").empty().hide();
			}

			// Cerrar con botón
			searchClose.on("click", function (e) {
				e.preventDefault();
				closeSearch();
			});

			// Cerrar con ESC
			$(document).on("keydown", function (e) {
				if (e.key === "Escape" && searchWrapper.hasClass("show")) {
					closeSearch();
				}
			});

			// Evitar cierre al hacer clic dentro
			searchWrapper.find(".tp-search-inner").on("click", function (e) {
				e.stopPropagation();
			});

			// Cerrar al hacer clic fuera
			searchWrapper.on("click", function (e) {
				if ($(e.target).is(searchWrapper)) {
					closeSearch();
				}
			});

			// Manejar input de búsqueda y teclas especiales
			searchInput.on("input keydown", function (e) {
				if (e.type === 'keydown') {
					// Manejar teclas especiales
					const $suggestions = $('.search-suggestions .suggestion-item');
					const $highlighted = $suggestions.filter('.highlighted');
					
					switch (e.key) {
						case 'ArrowDown':
							e.preventDefault();
							if ($highlighted.length === 0) {
								$suggestions.first().addClass('highlighted');
							} else {
								$highlighted.removeClass('highlighted')
									.next('.suggestion-item')
									.addClass('highlighted');
							}
							break;
							
						case 'ArrowUp':
							e.preventDefault();
							if ($highlighted.length === 0) {
								$suggestions.last().addClass('highlighted');
							} else {
								$highlighted.removeClass('highlighted')
									.prev('.suggestion-item')
									.addClass('highlighted');
							}
							break;
							
						case 'Enter':
							if ($highlighted.length) {
								e.preventDefault();
								window.location.href = $highlighted.data('url');
							}
							break;
					}
					return;
				}

				// Manejar input
				clearTimeout(searchTimeout);
				const query = $(this).val().trim();
				
				if (query.length >= 2) {
					searchTimeout = setTimeout(() => {
						performSearch(query);
					}, 300);
				} else {
					$(".search-suggestions").empty().hide();
				}
			});

			// Función de búsqueda mejorada
			async function performSearch(query) {
				try {
					// Usar caché si existe
					if (searchCache.has(query)) {
						displayResults(searchCache.get(query), query);
						return;
					}

					const index = await loadSearchIndex();
					const searchTerms = query.toLowerCase().split(/\s+/).filter(term => term.length > 1);
					
					const results = index
						.map(item => {
							const titleLower = item.title.toLowerCase();
							const contentLower = (item.content || '').toLowerCase();
							const excerptLower = (item.excerpt || '').toLowerCase();
							const tagsLower = item.tags.map(t => t.toLowerCase());
							
							let score = 0;
							let matches = [];

							// Coincidencia exacta en título
							if (titleLower.includes(query.toLowerCase())) {
								score += 100;
								matches.push('título');
							}

							// Coincidencia exacta en contenido
							if (contentLower.includes(query.toLowerCase())) {
								score += 50;
								matches.push('contenido');
							}

							// Coincidencia en tags
							if (tagsLower.some(tag => tag.includes(query.toLowerCase()))) {
								score += 75;
								matches.push('etiquetas');
							}

							// Coincidencias parciales
							searchTerms.forEach(term => {
								if (titleLower.includes(term)) score += 20;
								if (excerptLower.includes(term)) score += 10;
								if (contentLower.includes(term)) score += 5;
								if (tagsLower.some(tag => tag.includes(term))) score += 15;
							});

							return {
								...item,
								score,
								matches,
							};
						})
						.filter(item => item.score > 0)
						.sort((a, b) => b.score - a.score)
						.slice(0, 6);

					// Guardar en caché
					searchCache.set(query, results);
					displayResults(results, query);
				} catch (error) {
					console.error("Error en la búsqueda:", error);
					displayResults([], query);
				}
			}

			// Mostrar resultados
			function displayResults(results, query) {
				const suggestionsContainer = $(".search-suggestions");
				
				if (results.length === 0) {
					suggestionsContainer.html(`
						<div class="no-results">
							<p>No se encontraron resultados para "${query}"</p>
						</div>
					`).show();
					return;
				}

				const html = results.map(result => `
					<div class="suggestion-item" data-url="${result.url}">
						<div class="suggestion-title">${highlightText(result.title, query)}</div>
						<div class="suggestion-excerpt">${highlightText(result.excerpt, query)}</div>
						<div class="suggestion-category">
							${result.tags.map(tag => `<span class="tag">${tag}</span>`).join("")}
						</div>
					</div>
				`).join("");

				suggestionsContainer.html(html).show();

				// Manejar clics en sugerencias
				$(".suggestion-item").on("click", function() {
					const url = $(this).data("url");
					if (url) {
						window.location.href = url;
					}
				});
			}

			// Resaltar texto de búsqueda
			function highlightText(text, query) {
				if (!text) return "";
				const regex = new RegExp(`(${escapeRegExp(query)})`, "gi");
				return text.replace(regex, '<span class="search-highlight">$1</span>');
			}

			// Escapar caracteres especiales para regex
			function escapeRegExp(string) {
				return string.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
			}
		}

		// Inicializar búsqueda cuando el DOM esté listo
		$(document).ready(function() {
			initializeSearch();
		});

	////////////////////////////////////////////////////
	// 16. Cart Quantity Js
	$('.cart-minus').on('click', function () {
		var $input = $(this).parent().find('input');
		var count = parseInt($input.val()) - 1;
		count = count < 1 ? 1 : count;
		$input.val(count);
		$input.change();
		return false;
	});

	$('.cart-plus').on('click', function () {
		var $input = $(this).parent().find('input');
		$input.val(parseInt($input.val()) + 1);
		$input.change();
		return false;
	});


	/* Price filter active */

	if ($("#slider-range").length) {

		$("#slider-range").slider({

			range: true,

			min: 0,

			max: 500,

			values: [75, 300],

			slide: function (event, ui) {

				$("#amount").val("$" + ui.values[0] + " - $" + ui.values[1]);

			}

		});

		$("#amount").val("$" + $("#slider-range").slider("values", 0) +

			" - $" + $("#slider-range").slider("values", 1));

		$('#filter-btn').on('click', function () {

			$('.filter-widget').slideToggle(1000);

		});

	}


	
	// 08. Nice Select Js
	$('select').niceSelect();


})(jQuery);