(function ($) {
	"use strict";
	
	// Módulo de búsqueda global
	var TPSearch = {
		searchInput: null,
		suggestions: null,
		searchWrapper: null,
		searchBox: null,
		searchClose: null,
		searchTimeout: null,
		searchIndex: null,
		searchCache: new Map(),
		
		init: function() {
			// Inicializar elementos
			this.searchInput = $(".tp-search-form input");
			this.suggestions = $(".search-suggestions");
			this.searchWrapper = $(".tp-search-wrapper");
			this.searchBox = $(".tp-search-box");
			this.searchClose = $(".tp-search-close");
			
			// Cargar datos de búsqueda
			this.loadSearchIndex();
			
			// Vincular eventos
			this.bindEvents();
		},
		
		loadSearchIndex: function() {
			var self = this;
			return $.getJSON("assets/js/search-index.json")
				.then(function(data) {
					self.searchIndex = data;
					console.log("Search index loaded successfully");
				})
				.catch(function(error) {
					console.error("Error loading search index:", error);
				});
		},
		
		bindEvents: function() {
			var self = this;
			
			// Eventos de entrada de búsqueda
			this.searchInput.on("input", this.debounce(function() {
				var query = $(this).val().trim();
				self.handleSearch(query);
			}, 300));
			
			// Navegación con teclado
			this.searchInput.on("keydown", this.handleKeyNav.bind(this));
			
			// Abrir/cerrar búsqueda
			this.searchBox.on("click", function(e) {
				e.preventDefault();
				e.stopPropagation();
				self.openSearch();
			});
			
			// Cerrar búsqueda
			this.searchClose.on("click", function(e) {
				e.preventDefault();
				self.closeSearch();
			});
			
			// Cerrar al hacer clic fuera
			$(document).on("click", function(e) {
				if (!$(e.target).closest('.tp-search-wrapper').length) {
					self.closeSearch();
				}
			});
			
			// Cerrar con ESC
			$(document).on("keydown", function(e) {
				if (e.key === "Escape") {
					self.closeSearch();
				}
			});
		},
		
		// Función utilitaria para debounce
		debounce: function(func, wait) {
			var timeout;
			return function executedFunction() {
				var context = this;
				var args = arguments;
				clearTimeout(timeout);
				timeout = setTimeout(function() {
					func.apply(context, args);
				}, wait);
			};
		},
		
		handleSearch: function(query) {
			if (query.length < 2) {
				this.suggestions.empty().hide();
				return;
			}
			
			if (this.searchCache.has(query)) {
				this.showSuggestions(this.searchCache.get(query), query);
				return;
			}
			
			this.performSearch(query);
		},
		
		handleKeyNav: function(e) {
			var $items = this.suggestions.find(".suggestion-item");
			var $highlighted = $items.filter(".highlighted");
			
			switch (e.key) {
				case "ArrowDown":
					e.preventDefault();
					if ($highlighted.length === 0) {
						$items.first().addClass("highlighted");
					} else {
						$highlighted.removeClass("highlighted")
							.next(".suggestion-item").addClass("highlighted");
					}
					break;
					
				case "ArrowUp":
					e.preventDefault();
					if ($highlighted.length === 0) {
						$items.last().addClass("highlighted");
					} else {
						$highlighted.removeClass("highlighted")
							.prev(".suggestion-item").addClass("highlighted");
					}
					break;
					
				case "Enter":
					if ($highlighted.length) {
						e.preventDefault();
						window.location.href = $highlighted.data("url");
					}
					break;
					
				case "Escape":
					this.closeSearch();
					break;
			}
		},
		
		openSearch: function() {
			this.searchWrapper.addClass("search-open");
			setTimeout(() => {
				this.searchInput.val("").focus();
			}, 100);
			$("body").addClass("search-active");
		},
		
		closeSearch: function() {
			this.searchWrapper.removeClass("search-open");
			this.suggestions.empty().hide();
			this.searchInput.val("");
			$("body").removeClass("search-active");
		},
		
		performSearch: function(query) {
			if (!this.searchIndex) {
				console.warn("Search index not loaded yet");
				return;
			}
			
			var queryLower = query.toLowerCase();
			var searchTerms = queryLower.split(/\s+/).filter(term => term.length > 1);
			
			var results = this.searchIndex
				.map(item => {
					var titleLower = item.title.toLowerCase();
					var contentLower = (item.content || "").toLowerCase();
					var excerptLower = (item.excerpt || "").toLowerCase();
					var tagsLower = (item.tags || []).map(t => t.toLowerCase());
					
					var score = 0;
					var matches = [];
					
					// Coincidencia exacta en título
					if (titleLower.includes(queryLower)) {
						score += 100;
						matches.push("título");
					}
					
					// Coincidencia en contenido
					if (contentLower.includes(queryLower)) {
						score += 50;
						matches.push("contenido");
					}
					
					// Coincidencia en tags
					if (tagsLower.some(tag => tag.includes(queryLower))) {
						score += 75;
						matches.push("etiquetas");
					}
					
					// Coincidencias parciales
					searchTerms.forEach(term => {
						if (titleLower.includes(term)) score += 20;
						if (excerptLower.includes(term)) score += 10;
						if (contentLower.includes(term)) score += 5;
						if (tagsLower.some(tag => tag.includes(term))) score += 15;
					});
					
					return {
						title: item.title,
						excerpt: item.excerpt || "",
						url: item.url,
						tags: item.tags || [],
						score: score,
						matches: matches
					};
				})
				.filter(item => item.score > 0)
				.sort((a, b) => b.score - a.score)
				.slice(0, 6);
			
			this.searchCache.set(query, results);
			this.showSuggestions(results, query);
		},
		
		showSuggestions: function(results, query) {
			if (!results || results.length === 0) {
				this.suggestions.html(`
					<div class="suggestion-item no-results">
						<div class="suggestion-title">No se encontraron resultados para "${this.escapeHtml(query)}"</div>
					</div>
				`).show();
				return;
			}
			
			var html = results.map(result => `
				<div class="suggestion-item" data-url="${this.escapeHtml(result.url)}">
					<div class="suggestion-title">${this.highlightText(result.title, query)}</div>
					<div class="suggestion-excerpt">${this.highlightText(result.excerpt, query)}</div>
					<div class="suggestion-meta">
						${result.matches.length > 0 ? 
							`<div class="suggestion-matches">${result.matches.join(" · ")}</div>` : 
							""}
						${result.tags.length > 0 ? 
							`<div class="suggestion-tags">${result.tags.map(tag => 
								`<span class="tag">${this.escapeHtml(tag)}</span>`).join("")}</div>` : 
							""}
					</div>
				</div>
			`).join("");
			
			this.suggestions.html(html).show();
			
			// Bind click events
			this.suggestions.find(".suggestion-item").on("click", function() {
				window.location.href = $(this).data("url");
			});
		},
		
		highlightText: function(text, query) {
			if (!text) return "";
			var regex = new RegExp("(" + this.escapeRegExp(query) + ")", "gi");
			return text.replace(regex, '<span class="search-highlight">$1</span>');
		},
		
		escapeRegExp: function(string) {
			return string.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
		}
	};

	var windowOn = $(window)
